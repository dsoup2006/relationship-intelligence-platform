{
  "name": "nexus-relationship-intelligence-platform",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "build:client": "npm run build --workspace client",
    "start:server": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
